generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  OPERATOR
  VIEWER
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  role         UserRole @default(OPERATOR)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model VpsServer {
  id                String   @id @default(cuid())
  name              String
  host              String
  port              Int      @default(22)
  username          String
  authType          String
  privateKeyEnc     String?
  passwordEnc       String?
  passphraseEnc     String?
  fingerprint       String?
  defaultProjectDir String   @default("/opt/strapi-sites")
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  projects          Project[]

  @@unique([host, port, username])
}

model Project {
  id                  String   @id @default(cuid())
  name                String
  siteName            String
  repoUrl             String
  branch              String   @default("main")
  domain              String?
  frontendDomain      String?
  strapiPort          Int?
  adminerPort         Int?
  frontendPort        Int?
  backendPath         String
  frontendPath        String?
  envBackendPath      String?
  envFrontendPath     String?
  deployFrontendVps   Boolean  @default(false)
  cloudflareProject   String?
  dbName              String?
  dbUsername          String?
  dbPasswordEnc       String?
  serverId            String
  server              VpsServer @relation(fields: [serverId], references: [id], onDelete: Cascade)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  activityLogs        ActivityLog[]

  @@unique([serverId, siteName])
}

model ActivityLog {
  id        String   @id @default(cuid())
  projectId String
  actorId   String?
  action    String
  output    String?
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model DeploymentJob {
  id        String   @id @default(cuid())
  status    String   @default("PENDING") // PENDING | RUNNING | SUCCESS | FAILED
  log       String   @default("")
  projectId String?
  serverId  String
  actorId   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
